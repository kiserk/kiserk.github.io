---

---

<video
  id="water-video"
  class="fixed inset-0 -z-10 w-screen h-screen object-cover"
  autoplay
  muted
  loop
  playsinline
  preload="auto"
  poster="/water/IMG_5047_twilight_mono.jpg"
  aria-hidden="true"
  style="display:none"
>
  <source src="/water/IMG_5047_twilight_mono.mp4" type="video/mp4" />
  <source src="/water/IMG_5047_twilight_mono.webm" type="video/webm" />
</video>
<canvas id="ocean-canvas" class="fixed inset-0 -z-10 w-screen h-screen"></canvas>
<div
  class="fixed inset-0 w-screen h-screen pointer-events-none"
  style="z-index: -5; background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.24) 48%, rgba(0,0,0,0.24) 85%, rgba(0,0,0,0.55) 100%);"
  aria-hidden="true"
></div>

<script>
  import { getOceanData } from '../scripts/ocean-data';
  import { computeVisuals } from '../scripts/ocean-palette';
  import { OceanRenderer } from '../scripts/ocean-renderer';

  const DATA_REFRESH_INTERVAL = 30 * 60 * 1000;

  function applyTextStyles(visuals: { textColor: string; textShadow: string }) {
    document.documentElement.style.setProperty('--text-color', visuals.textColor);
    document.documentElement.style.setProperty('--text-shadow', visuals.textShadow);
  }

  // Plain looping video unless the device/user prefers otherwise, in which
  // case we fall back to the procedural ocean canvas.
  function canUseVideo(): boolean {
    try {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return false;
      const conn = (navigator as any).connection;
      if (conn && conn.saveData) return false;
      return true;
    } catch {
      return false;
    }
  }

  function init() {
    const video = document.getElementById('water-video') as HTMLVideoElement | null;
    const oceanCanvas = document.getElementById('ocean-canvas') as HTMLCanvasElement | null;
    if (!video || !oceanCanvas) return;

    let oceanRenderer: OceanRenderer | null = null;
    let intervalId: number | undefined;

    function startCanvasFallback() {
      if (oceanRenderer) return;
      try {
        video!.pause();
      } catch {
        // ignore
      }
      video!.style.display = 'none';
      oceanCanvas!.style.display = '';
      oceanRenderer = new OceanRenderer(oceanCanvas!);
      const initialVisuals = computeVisuals(null);
      oceanRenderer.updateVisuals(initialVisuals);
      applyTextStyles(initialVisuals);
      oceanRenderer.start();

      const refresh = async () => {
        try {
          const data = await getOceanData();
          const visuals = computeVisuals(data);
          oceanRenderer?.updateVisuals(visuals);
          applyTextStyles(visuals);
        } catch {
          // data fetch failed; renderer keeps last known visuals
        }
      };
      refresh();
      intervalId = window.setInterval(refresh, DATA_REFRESH_INTERVAL);

      const onResize = () => oceanRenderer?.resize();
      window.addEventListener('resize', onResize);
      window.addEventListener('unload', () => {
        if (intervalId) clearInterval(intervalId);
        window.removeEventListener('resize', onResize);
        oceanRenderer?.destroy();
      });
    }

    if (canUseVideo()) {
      oceanCanvas.style.display = 'none';
      video.style.display = '';
      applyTextStyles(computeVisuals(null));

      const playAttempt = video.play();
      if (playAttempt && typeof playAttempt.catch === 'function') {
        playAttempt.catch(() => startCanvasFallback());
      }
      // If autoplay silently fails (still paused), fall back.
      window.setTimeout(() => {
        if (video.paused || video.readyState < 2) startCanvasFallback();
      }, 5000);
    } else {
      startCanvasFallback();
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
