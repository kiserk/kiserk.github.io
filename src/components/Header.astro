---
const navItems = [
  { label: 'CV', href: '/cv' },
  { label: 'Publications', href: '/publications' },
  { label: 'Patents', href: '/patents' },
  { label: 'Projects', href: '/projects' },
  { label: 'Swell', href: '/swell' },
  { label: 'Golden Hour', href: '/golden-hour' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header
  class="fixed top-0 left-0 right-0 z-50 px-6 py-5 md:px-10"
  style={`color: var(--text-color, rgba(246, 244, 240, 0.96)); text-shadow: var(--text-shadow, 0 1px 14px rgba(0,0,0,0.55));`}
>
  <div class="flex items-center justify-between max-w-7xl mx-auto">
    <a
      href="/"
      class="font-[family-name:var(--font-heading)] text-sm font-normal tracking-widest uppercase opacity-90 hover:opacity-100 transition-opacity duration-300"
      style="color: inherit;"
    >
      Karl Kiser
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {navItems.map((item) => {
        const isActive = currentPath === item.href;
        return (
          <a
            href={item.href}
            class:list={[
              'text-xs font-normal tracking-wider uppercase transition-opacity duration-300',
              isActive ? 'opacity-100' : 'opacity-65 hover:opacity-100',
            ]}
            style="color: inherit; text-decoration: none;"
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <button
      id="mobile-menu-toggle"
      class="md:hidden opacity-60 hover:opacity-100 transition-opacity duration-300"
      aria-label="Toggle navigation"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="md:hidden hidden flex-col items-end gap-5 pt-6 pb-2"
    style={`color: var(--text-color, rgba(246, 244, 240, 0.96)); text-shadow: var(--text-shadow, 0 1px 14px rgba(0,0,0,0.55));`}
  >
    {navItems.map((item) => {
      const isActive = currentPath === item.href;
      return (
        <a
          href={item.href}
          class:list={[
            'text-sm font-normal tracking-wider uppercase transition-opacity duration-300',
            isActive ? 'opacity-100' : 'opacity-70 hover:opacity-100',
          ]}
          style="color: inherit; text-decoration: none;"
        >
          {item.label}
        </a>
      );
    })}
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      menu.classList.toggle('flex');
    });
  }
</script>
