---
import BaseLayout from '../layouts/BaseLayout.astro';
import OceanBackground from '../components/OceanBackground.astro';
import Header from '../components/Header.astro';
---

<BaseLayout title="Surf — Karl Kiser">
  <OceanBackground />
  <Header />

  <main
    class="relative z-10 min-h-screen px-5 pt-24 pb-20 md:pt-32 md:pb-28"
    style={`color: var(--ink)`}
  >
    <div class="mx-auto max-w-[760px]">

      <div class="mb-8 opacity-0 translate-y-4 animate-fade-in">
        <select
          id="spot-selector"
          class="surface w-full rounded-xl px-5 py-4 text-base tracking-wide appearance-none cursor-pointer focus:outline-none transition-colors duration-300"
          style="color: var(--ink); background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2214%22 height=%2214%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22rgba(245,240,235,0.6)%22 stroke-width=%222%22><polyline points=%226 9 12 15 18 9%22/></svg>'); background-repeat: no-repeat; background-position: right 16px center;"
        >
          <option>Loading spots...</option>
        </select>
      </div>

      <div
        id="windy-container"
        class="mb-8 opacity-0 translate-y-4 animate-fade-in"
        style="animation-delay: 0.1s;"
      >
        <div class="surface rounded-2xl overflow-hidden">
          <iframe
            id="windy-map"
            class="w-full"
            style="aspect-ratio: 16 / 9; border: none;"
            loading="lazy"
          ></iframe>
          <div class="flex items-center justify-between px-5 py-3 border-t border-white/10">
            <span class="text-[0.8rem]" style="color: var(--ink-faint);">Live wave & wind conditions via Windy.com</span>
            <a
              id="cam-link"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm opacity-80 hover:opacity-100 transition-opacity no-underline hidden"
              style="color: var(--ink);"
            >
              Watch surf cam ↗
            </a>
          </div>
        </div>
      </div>

      <div
        class="surface rounded-2xl px-7 py-8 md:px-10 md:py-10 mb-8 opacity-0 translate-y-4 animate-fade-in"
        style="animation-delay: 0.15s;"
      >
        <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-8">
          <h2 class="font-[family-name:var(--font-heading)] text-xl md:text-2xl font-light tracking-wide">
            <span id="spot-name">Loading...</span>
          </h2>
          <span id="current-date" class="text-sm tracking-wider" style="color: var(--ink-faint);"></span>
        </div>
        <div id="conditions-grid" class="space-y-4">
          <p class="text-base animate-pulse" style="color: var(--ink-faint);">Loading conditions...</p>
        </div>
      </div>

      <div
        id="hourly-section"
        class="surface rounded-2xl px-7 py-8 md:px-10 md:py-10 mb-8 opacity-0 translate-y-4 animate-fade-in"
        style="animation-delay: 0.25s;"
      >
        <h2 class="font-[family-name:var(--font-heading)] text-lg md:text-xl font-light tracking-wide mb-6">
          Hourly Breakdown
          <span class="text-sm font-normal tracking-wider ml-2" style="color: var(--ink-faint);">Dawn to Noon</span>
        </h2>
        <div class="overflow-x-auto -mx-2">
          <table id="hourly-table" class="w-full text-base">
            <tbody>
              <tr><td class="py-3 text-base animate-pulse" style="color: var(--ink-faint);">Loading hourly data...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <div
        id="forecast-section"
        class="surface rounded-2xl px-7 py-8 md:px-10 md:py-10 mb-8 opacity-0 translate-y-4 animate-fade-in"
        style="animation-delay: 0.35s;"
      >
        <h2 class="font-[family-name:var(--font-heading)] text-lg md:text-xl font-light tracking-wide mb-6">
          7-Day Look-Ahead
        </h2>
        <div class="overflow-x-auto -mx-2">
          <table id="forecast-table" class="w-full text-base">
            <tbody>
              <tr><td class="py-3 text-base animate-pulse" style="color: var(--ink-faint);">Loading forecast...</td></tr>
            </tbody>
          </table>
        </div>
        <p class="text-sm mt-5" style="color: var(--ink-faint);">★ = Best days this week</p>
      </div>

    </div>
  </main>
</BaseLayout>

<script>
  import { initSurfPage } from '../scripts/surf-page';
  initSurfPage();
</script>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(1rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 1.2s ease-out 0.3s forwards;
  }
</style>
