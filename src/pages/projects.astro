---
import BaseLayout from '../layouts/BaseLayout.astro';
import OceanBackground from '../components/OceanBackground.astro';
import Header from '../components/Header.astro';
import ProjectsSection from '../components/sections/ProjectsSection.astro';
---

<BaseLayout
  title="Projects — Karl Kiser"
  description="Selected work by Karl Kiser: aerial-mycelium process development and technology transfer, and quantitative MRI methods for tumor treatment response."
  path="/projects"
>
  <OceanBackground />
  <Header />

  <main class="relative z-10 min-h-screen pt-8 md:pt-10">
    <ProjectsSection />
  </main>
</BaseLayout>
