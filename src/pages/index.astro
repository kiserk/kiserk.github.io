---
import BaseLayout from '../layouts/BaseLayout.astro';
import OceanBackground from '../components/OceanBackground.astro';
import Header from '../components/Header.astro';
import { SITE } from '../config/site';
---

<BaseLayout
  title="Karl Kiser — Biomaterials & R&D Engineer"
  description={SITE.tagline}
  path="/"
>
  <OceanBackground />
  <Header />

  <main
    class="relative z-10 flex items-center justify-center min-h-screen px-6"
    style={`color: var(--text-color, rgba(246, 244, 240, 0.96)); text-shadow: var(--text-shadow, 0 1px 14px rgba(0,0,0,0.55));`}
  >
    <div class="relative text-center opacity-0 translate-y-4 animate-fade-in">
      <h1 class="font-[family-name:var(--font-heading)] text-[2rem] md:text-[3rem] font-light tracking-[0.2em] uppercase">
        Karl Kiser
      </h1>

      <div class="w-10 h-px mx-auto mt-6 mb-6 opacity-50" style="background: currentColor;"></div>

      <p class="text-sm md:text-base tracking-[0.04em] opacity-90 max-w-xl mx-auto leading-relaxed">
        {SITE.tagline}
      </p>

      <p class="text-xs tracking-[0.3em] uppercase opacity-65 mt-5">
        {SITE.location.locality}
      </p>

      {SITE.openTo && (
        <p class="text-[0.8rem] tracking-wide opacity-70 mt-4 max-w-md mx-auto">
          {SITE.openTo}
        </p>
      )}

      <p class="sr-only">{SITE.bio}</p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-10">
        <a
          href="/cv"
          class="inline-flex items-center gap-2 rounded-full border px-6 py-2.5 text-xs tracking-[0.2em] uppercase opacity-90 hover:opacity-100 transition-opacity duration-300"
          style="color: inherit; text-decoration: none; border-color: currentColor;"
          data-goatcounter-click="cta-view-cv"
        >
          View CV
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
          </svg>
        </a>

        <a
          href="/Karl-Kiser-CV.pdf"
          download
          class="inline-flex items-center gap-2 text-xs tracking-[0.2em] uppercase opacity-70 hover:opacity-100 transition-opacity duration-300"
          style="color: inherit; text-decoration: none;"
          data-goatcounter-click="cv-download"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><path d="M7 10l5 5 5-5" /><path d="M12 15V3" />
          </svg>
          Download PDF
        </a>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3 mt-8">
        <a
          href={`mailto:${SITE.email}`}
          class="flex items-center gap-2 text-sm opacity-80 hover:opacity-100 transition-opacity duration-300"
          style="color: inherit; text-decoration: none;"
          data-goatcounter-click="contact-email"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
          {SITE.email}
        </a>

        <a
          href={SITE.profiles.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm opacity-80 hover:opacity-100 transition-opacity duration-300"
          style="color: inherit; text-decoration: none;"
          data-goatcounter-click="profile-linkedin"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
          LinkedIn
        </a>

        {SITE.profiles.orcid && (
          <a
            href={SITE.profiles.orcid}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm opacity-80 hover:opacity-100 transition-opacity duration-300"
            style="color: inherit; text-decoration: none;"
            data-goatcounter-click="profile-orcid"
          >
            ORCID
          </a>
        )}

        {SITE.profiles.googleScholar && (
          <a
            href={SITE.profiles.googleScholar}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm opacity-80 hover:opacity-100 transition-opacity duration-300"
            style="color: inherit; text-decoration: none;"
            data-goatcounter-click="profile-scholar"
          >
            Google Scholar
          </a>
        )}

        {SITE.profiles.github && (
          <a
            href={SITE.profiles.github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm opacity-80 hover:opacity-100 transition-opacity duration-300"
            style="color: inherit; text-decoration: none;"
            data-goatcounter-click="profile-github"
          >
            GitHub
          </a>
        )}
      </div>

      <div class="mt-9">
        <a
          href="https://join.ctf.org/fundraiser/7268167"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[0.7rem] tracking-[0.15em] uppercase opacity-50 hover:opacity-80 transition-opacity duration-300"
          style="color: inherit; text-decoration: none;"
          data-goatcounter-click="marathon-fundraiser"
        >
          Supporting the NYC Marathon for CTF →
        </a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(1rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 1.2s ease-out 0.3s forwards;
  }
</style>
