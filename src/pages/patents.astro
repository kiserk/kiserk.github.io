---
import BaseLayout from '../layouts/BaseLayout.astro';
import OceanBackground from '../components/OceanBackground.astro';
import Header from '../components/Header.astro';
import PatentsSection from '../components/sections/PatentsSection.astro';

const patentSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  '@id': 'https://patents.google.com/patent/US20240352400A1',
  name: 'Growth Media Compositions and Growth Environmental Conditions for Improved Aerial Mycelium',
  author: [
    { '@type': 'Person', name: 'Jacob Michael Winiski' },
    { '@type': 'Person', name: 'Karl John Kiser' },
  ],
  datePublished: '2024-10-24',
  publisher: { '@type': 'Organization', name: 'Ecovative LLC' },
  identifier: 'US 2024/0352400 A1',
  sameAs: [
    'https://patents.google.com/patent/US20240352400A1',
    'https://patents.google.com/patent/WO2024226467A1',
  ],
  about: 'Aerial mycelium cultivation, growth media compositions, environmental control',
};
---

<BaseLayout
  title="Patents — Karl Kiser"
  description="Patent by Karl Kiser: US 2024/0352400 A1 covering growth media compositions and environmental conditions for improved aerial mycelium cultivation."
  path="/patents"
  jsonLd={[patentSchema]}
>
  <OceanBackground />
  <Header />

  <main class="relative z-10 min-h-screen pt-8 md:pt-10">
    <PatentsSection />
  </main>
</BaseLayout>
