---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---

<BaseLayout
  title="Golden Hour — Karl Kiser"
  description="A live beach cam, somewhere in the world, at sunset or sunrise right now."
>
  <Header />

  <main class="cam-stage">
    <!-- Full-bleed live cam (cropped to cover the viewport). -->
    <div class="cam-cover">
      <iframe
        id="cam-frame"
        title="Live beach cam"
        frameborder="0"
        allow="autoplay; encrypted-media; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>

    <!-- Dark vignette so overlay text stays readable over any scene. -->
    <div class="cam-vignette" aria-hidden="true"></div>

    <!-- Sunset / Sunrise toggle -->
    <div class="cam-controls opacity-0 animate-fade-in">
      <div
        class="surface inline-flex items-center rounded-full p-1 text-xs tracking-[0.18em] uppercase"
        role="group"
        aria-label="Choose golden hour"
      >
        <button id="mode-sunset" type="button" class="mode-btn" data-mode="sunset">
          Sunset
        </button>
        <button id="mode-sunrise" type="button" class="mode-btn" data-mode="sunrise">
          Sunrise
        </button>
      </div>
    </div>

    <!-- Current location + credit -->
    <div class="cam-caption opacity-0 animate-fade-in" style="animation-delay: 0.1s;">
      <p id="cam-name" class="cam-name">Finding the light…</p>
      <p id="cam-location" class="cam-location"></p>
      <div class="cam-actions">
        <a
          id="cam-watch"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="cam-credit"
        >
          <span id="cam-credit-label">Live cam</span> ↗
        </a>
        <button id="next-cam" type="button" class="next-cam-btn" title="Cam not loading? Try the next nearest one">
          Next cam ›
        </button>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  import { CAMS, embedUrl, watchUrl, type SunsetCam } from '../scripts/sunset-cams';
  import { solarPosition, scoreCam, type GoldenHourMode } from '../scripts/sun';

  const frame = document.getElementById('cam-frame') as HTMLIFrameElement | null;
  const nameEl = document.getElementById('cam-name');
  const locationEl = document.getElementById('cam-location');
  const watchEl = document.getElementById('cam-watch') as HTMLAnchorElement | null;
  const creditEl = document.getElementById('cam-credit-label');
  const nextBtn = document.getElementById('next-cam') as HTMLButtonElement | null;
  const buttons = Array.from(
    document.querySelectorAll<HTMLButtonElement>('.mode-btn'),
  );

  const STORAGE_KEY = 'golden-hour-mode';
  let mode: GoldenHourMode =
    (localStorage.getItem(STORAGE_KEY) as GoldenHourMode) === 'sunrise'
      ? 'sunrise'
      : 'sunset';

  // Id of the cam currently shown (avoids needless iframe reloads).
  let currentId: string | null = null;
  // Id of the current best cam, i.e. the golden-hour "region" anchor. When this
  // changes the Earth has rotated enough to move to a new place, so any manual
  // "next cam" choice is reset back to the best one.
  let anchorId: string | null = null;
  // Manual fallback offset into the score-ranked list. 0 = the best cam; the
  // "Next cam" button steps to the next-nearest candidate (same golden hour),
  // for when the auto-picked cam happens to be offline.
  let offset = 0;

  // All cams ranked by how close they are to the requested golden hour, best
  // first. Adjacent entries are the nearest regional alternatives.
  function rankCams(now: Date): SunsetCam[] {
    return CAMS.map((cam) => ({
      cam,
      score: scoreCam(solarPosition(cam.lat, cam.lon, now), mode),
    }))
      .sort((a, b) => a.score - b.score)
      .map((entry) => entry.cam);
  }

  function show(cam: SunsetCam) {
    if (cam.id === currentId) return;
    currentId = cam.id;
    if (frame) frame.src = embedUrl(cam);
    if (nameEl) nameEl.textContent = cam.name;
    if (locationEl) locationEl.textContent = cam.location;
    if (watchEl) watchEl.href = watchUrl(cam);
    if (creditEl) creditEl.textContent = `Live · ${cam.credit}`;
  }

  // Auto selection: follow the globe. Only reset a manual "next" choice once the
  // best (anchor) cam actually changes region.
  function autoRender() {
    const ranked = rankCams(new Date());
    if (ranked[0].id !== anchorId) {
      anchorId = ranked[0].id;
      offset = 0;
    }
    show(ranked[offset % ranked.length]);
  }

  // Manual fallback: advance to the next-nearest cam without leaving the region.
  function nextCam() {
    const ranked = rankCams(new Date());
    anchorId = ranked[0].id; // stay in sync so autoRender won't yank us back
    offset = (offset + 1) % ranked.length;
    show(ranked[offset]);
  }

  function setMode(next: GoldenHourMode) {
    mode = next;
    localStorage.setItem(STORAGE_KEY, mode);
    for (const btn of buttons) {
      btn.classList.toggle('is-active', btn.dataset.mode === mode);
    }
    offset = 0;
    anchorId = null;
    currentId = null;
    autoRender();
  }

  for (const btn of buttons) {
    btn.addEventListener('click', () => setMode(btn.dataset.mode as GoldenHourMode));
  }
  nextBtn?.addEventListener('click', nextCam);

  setMode(mode);

  // The Earth keeps turning: re-evaluate every 5 minutes and swap cams only
  // when a better golden-hour location is available (avoids needless reloads).
  setInterval(autoRender, 5 * 60 * 1000);
</script>

<style>
  .cam-stage {
    position: fixed;
    inset: 0;
    overflow: hidden;
    background: #05070d;
  }

  /* Scale the 16:9 iframe up so it always covers the viewport (object-fit:cover
     style behaviour for an iframe). */
  .cam-cover {
    position: absolute;
    inset: 0;
  }

  .cam-cover iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100vw;
    height: 56.25vw; /* 16:9 of width */
    min-height: 100vh;
    min-width: 177.78vh; /* 16:9 of height */
    border: 0;
    pointer-events: auto;
  }

  .cam-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(120% 90% at 50% 40%, transparent 55%, rgba(0, 0, 0, 0.45) 100%),
      linear-gradient(to bottom, rgba(0, 0, 0, 0.35) 0%, transparent 22%, transparent 70%, rgba(0, 0, 0, 0.55) 100%);
  }

  .cam-controls {
    position: absolute;
    top: 5.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
  }

  .mode-btn {
    appearance: none;
    border: none;
    background: transparent;
    color: var(--ink-faint);
    cursor: pointer;
    padding: 0.55rem 1.3rem;
    border-radius: 9999px;
    font: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    transition: color 0.3s ease, background-color 0.3s ease;
  }

  .mode-btn:hover {
    color: var(--ink);
  }

  .mode-btn.is-active {
    color: var(--ink);
    background: rgba(255, 255, 255, 0.14);
  }

  .cam-caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 2rem;
    z-index: 20;
    text-align: center;
    padding: 0 1.5rem;
    color: var(--text-color);
    text-shadow: var(--text-shadow);
    pointer-events: none;
  }

  .cam-name {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 300;
    letter-spacing: 0.12em;
    margin: 0;
  }

  .cam-location {
    font-size: 0.85rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.78;
    margin: 0.35rem 0 0;
  }

  .cam-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 0.7rem;
  }

  .cam-credit {
    display: inline-block;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: inherit;
    opacity: 0.7;
    text-decoration: none;
    pointer-events: auto;
    transition: opacity 0.3s ease;
  }

  .cam-credit:hover {
    opacity: 1;
  }

  .next-cam-btn {
    appearance: none;
    border: 1px solid rgba(255, 255, 255, 0.35);
    background: rgba(0, 0, 0, 0.25);
    color: inherit;
    cursor: pointer;
    pointer-events: auto;
    font: inherit;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.4rem 0.95rem;
    border-radius: 9999px;
    opacity: 0.78;
    transition: opacity 0.3s ease, background-color 0.3s ease, border-color 0.3s ease;
  }

  .next-cam-btn:hover {
    opacity: 1;
    background: rgba(255, 255, 255, 0.16);
    border-color: rgba(255, 255, 255, 0.55);
  }

  @media (max-width: 640px) {
    .cam-name {
      font-size: 1.2rem;
    }
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .animate-fade-in {
    animation: fade-in 1.4s ease-out 0.3s forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in {
      animation: none;
      opacity: 1;
    }
  }
</style>
