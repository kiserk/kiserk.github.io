---
import BaseLayout from '../layouts/BaseLayout.astro';
import OceanBackground from '../components/OceanBackground.astro';
import Header from '../components/Header.astro';
import PublicationsSection from '../components/sections/PublicationsSection.astro';
import { articleSchemas } from '../data/publications';
---

<BaseLayout
  title="Publications — Karl Kiser"
  description="Peer-reviewed publications and ISMRM conference abstracts by Karl Kiser in quantitative MRI, pharmacokinetic modeling, and biomedical imaging."
  path="/publications"
  jsonLd={articleSchemas}
>
  <OceanBackground />
  <Header />

  <main class="relative z-10 min-h-screen pt-8 md:pt-10">
    <PublicationsSection />
  </main>
</BaseLayout>
