---
import BaseLayout from '../layouts/BaseLayout.astro';
import OceanBackground from '../components/OceanBackground.astro';
import Header from '../components/Header.astro';
import CvSection from '../components/sections/CvSection.astro';
---

<BaseLayout
  title="CV — Karl Kiser"
  description="Curriculum vitae of Karl Kiser: biomaterials and R&D engineer with experience in bioprocess development, sensor and control-system design, data-driven optimization, and quantitative MRI research."
  path="/cv"
>
  <OceanBackground />
  <Header />

  <main class="relative z-10 min-h-screen pt-8 md:pt-10">
    <CvSection />
  </main>
</BaseLayout>
