---
import BaseLayout from '../layouts/BaseLayout.astro';
import OceanBackground from '../components/OceanBackground.astro';
---

<BaseLayout title="Karl Kiser — CV">
  <OceanBackground />

  <main
    class="relative z-10 min-h-screen px-5 py-20 md:py-28"
    style={`color: var(--text-color, rgba(245, 240, 235, 0.92))`}
  >
    <a
      href="/"
      class="fixed top-6 left-6 z-20 flex items-center gap-1.5 text-xs tracking-wide opacity-50 hover:opacity-100 transition-opacity duration-300"
      style="color: inherit; text-decoration: none;"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6" />
      </svg>
      Back
    </a>

    <div class="mx-auto max-w-[700px] opacity-0 translate-y-4 animate-fade-in">
      <div class="bg-black/30 backdrop-blur-sm rounded-2xl px-7 py-10 md:px-12 md:py-14">

        <header class="mb-12">
          <h1 class="font-[family-name:var(--font-heading)] text-[1.75rem] md:text-[2.25rem] font-light tracking-[0.15em] uppercase">
            Karl Kiser
          </h1>
          <div class="w-8 h-px mt-4 mb-4 opacity-40" style="background: currentColor;"></div>
          <p class="text-xs tracking-[0.25em] uppercase opacity-50">
            Curriculum Vitae
          </p>
        </header>

        <section class="mb-12">
          <h2 class="font-[family-name:var(--font-heading)] text-sm tracking-[0.2em] uppercase opacity-70 mb-4">
            Summary
          </h2>
          <p class="text-sm md:text-[0.9375rem] leading-relaxed opacity-80">
            Applied biomaterials scientist and research engineer with experience spanning quantitative experimentation, controlled-environment biological systems, data-driven process optimization, and mycelium platform development. Co-inventor on aerial-mycelium cultivation IP. First-author scientific publications. Strong translator between lab experimentation, model-based analysis, and manufacturable process improvement.
          </p>
        </section>

        <section class="mb-12">
          <h2 class="font-[family-name:var(--font-heading)] text-sm tracking-[0.2em] uppercase opacity-70 mb-8">
            Experience
          </h2>

          <div class="relative pl-5 border-l border-current/10">
            <article class="mb-10 last:mb-0 relative">
              <div class="absolute -left-[1.4rem] top-1 w-2 h-2 rounded-full border border-current/40 bg-black/50"></div>
              <h3 class="font-[family-name:var(--font-heading)] text-base md:text-lg font-medium tracking-wide">
                Research Associate
              </h3>
              <p class="text-sm opacity-60 mt-0.5">
                Ecovative Design — Green Island, NY
              </p>
              <p class="text-xs opacity-40 mt-1 tracking-wider">2023 – 2026</p>
              <ul class="mt-4 space-y-2.5 text-sm leading-relaxed opacity-75">
                <li class="relative pl-4 before:content-[''] before:absolute before:left-0 before:top-[0.55em] before:w-1 before:h-1 before:rounded-full before:bg-current before:opacity-40">
                  Co-inventor on patent application covering growth media compositions and environmental conditions for improved aerial mycelium cultivation
                </li>
                <li class="relative pl-4 before:content-[''] before:absolute before:left-0 before:top-[0.55em] before:w-1 before:h-1 before:rounded-full before:bg-current before:opacity-40">
                  Process development for aerial mycelium production including media optimization, environmental programming, and growth condition tuning
                </li>
                <li class="relative pl-4 before:content-[''] before:absolute before:left-0 before:top-[0.55em] before:w-1 before:h-1 before:rounded-full before:bg-current before:opacity-40">
                  Contributed to cultivation platform supporting 25 real-time environmental conditions and AI-model-informed process decisions
                </li>
                <li class="relative pl-4 before:content-[''] before:absolute before:left-0 before:top-[0.55em] before:w-1 before:h-1 before:rounded-full before:bg-current before:opacity-40">
                  Worked at the intersection of strain development, environmental programming, whole-system optimization, and data-rich control of mycelium growth
                </li>
              </ul>
            </article>

            <article class="mb-10 last:mb-0 relative">
              <div class="absolute -left-[1.4rem] top-1 w-2 h-2 rounded-full border border-current/40 bg-black/50"></div>
              <h3 class="font-[family-name:var(--font-heading)] text-base md:text-lg font-medium tracking-wide">
                Research Associate
              </h3>
              <p class="text-sm opacity-60 mt-0.5">
                Department of Radiology, Weill Cornell Medical College — New York, NY
              </p>
              <p class="text-xs opacity-40 mt-1 tracking-wider">2020 – 2023</p>
              <ul class="mt-4 space-y-2.5 text-sm leading-relaxed opacity-75">
                <li class="relative pl-4 before:content-[''] before:absolute before:left-0 before:top-[0.55em] before:w-1 before:h-1 before:rounded-full before:bg-current before:opacity-40">
                  First-author publications in Scientific Reports and Tomography on dynamic contrast-enhanced MRI methods
                </li>
                <li class="relative pl-4 before:content-[''] before:absolute before:left-0 before:top-[0.55em] before:w-1 before:h-1 before:rounded-full before:bg-current before:opacity-40">
                  Designed and executed quantitative experiments on tumor treatment response using active contrast-encoding MRI
                </li>
                <li class="relative pl-4 before:content-[''] before:absolute before:left-0 before:top-[0.55em] before:w-1 before:h-1 before:rounded-full before:bg-current before:opacity-40">
                  Developed methods for cellular water exchange measurement, pharmacokinetic parameter estimation, and image texture analysis
                </li>
                <li class="relative pl-4 before:content-[''] before:absolute before:left-0 before:top-[0.55em] before:w-1 before:h-1 before:rounded-full before:bg-current before:opacity-40">
                  Presented research at ISMRM (International Society for Magnetic Resonance in Medicine) annual meetings
                </li>
              </ul>
            </article>
          </div>
        </section>

        <section class="mb-12">
          <h2 class="font-[family-name:var(--font-heading)] text-sm tracking-[0.2em] uppercase opacity-70 mb-6">
            Skills
          </h2>

          <div class="space-y-5">
            <div>
              <h3 class="font-[family-name:var(--font-heading)] text-xs tracking-[0.15em] uppercase opacity-50 mb-2.5">
                Biomaterials & Cultivation
              </h3>
              <div class="flex flex-wrap gap-2">
                {[
                  'Aerial mycelium cultivation',
                  'Fungal growth optimization',
                  'Media design',
                  'Substrate optimization',
                  'Environmental programming',
                  'Controlled-environment experimentation',
                  'Pilot-scale process development',
                ].map(skill => (
                  <span class="inline-block px-3 py-1 text-xs rounded-full border border-current/15 bg-white/5 opacity-70">
                    {skill}
                  </span>
                ))}
              </div>
            </div>

            <div>
              <h3 class="font-[family-name:var(--font-heading)] text-xs tracking-[0.15em] uppercase opacity-50 mb-2.5">
                Quantitative & Analytical
              </h3>
              <div class="flex flex-wrap gap-2">
                {[
                  'Experimental design (DOE)',
                  'Statistical analysis',
                  'Pharmacokinetic modeling',
                  'Image texture analysis',
                  'Data-driven process optimization',
                  'Reproducibility analysis',
                ].map(skill => (
                  <span class="inline-block px-3 py-1 text-xs rounded-full border border-current/15 bg-white/5 opacity-70">
                    {skill}
                  </span>
                ))}
              </div>
            </div>

            <div>
              <h3 class="font-[family-name:var(--font-heading)] text-xs tracking-[0.15em] uppercase opacity-50 mb-2.5">
                Research & Communication
              </h3>
              <div class="flex flex-wrap gap-2">
                {[
                  'Scientific writing',
                  'Peer-reviewed publication',
                  'Patent documentation',
                  'Conference presentation',
                  'Cross-functional collaboration',
                  'Technical translation',
                ].map(skill => (
                  <span class="inline-block px-3 py-1 text-xs rounded-full border border-current/15 bg-white/5 opacity-70">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </section>

        <section>
          <h2 class="font-[family-name:var(--font-heading)] text-sm tracking-[0.2em] uppercase opacity-70 mb-4">
            Education
          </h2>
          <div>
            <h3 class="font-[family-name:var(--font-heading)] text-base font-medium tracking-wide">
              Weill Cornell Medical College / NYU
            </h3>
            <p class="text-sm opacity-60 mt-1">
              Research training in quantitative imaging and MRI methods
            </p>
            <p class="text-xs opacity-40 mt-1 tracking-wider">2020 – 2023</p>
          </div>
        </section>

      </div>
    </div>
  </main>
</BaseLayout>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(1rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 1.2s ease-out 0.3s forwards;
  }
</style>
